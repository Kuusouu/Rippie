{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/node_modules/",
			"!**/dist/",
			"!**/built/",
			"!**/out/",
			"!**/build/",
			"!**/*.log",
			"!**/.env",
			"!**/.env.*",
			"!**/settings.json",
			"!**/config.json",
			"!**/bun.lock",
			"!**/bun.lockb",
			"!**/package-lock.json",
			"!**/yarn.lock",
			"!**/pnpm-lock.yaml",
			"!**/.vscode/",
			"!**/.idea/",
			"!**/.gemini/",
			"!**/.github/",
			"!**/*.tsbuildinfo",
			"!**/LICENSE"
		]
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 100,
		"indentStyle": "tab",
		"indentWidth": 4
	},
	"javascript": {
		"formatter": {
			"semicolons": "always",
			"quoteStyle": "single",
			"trailingCommas": "all",
			"bracketSpacing": true,
			"quoteProperties": "asNeeded"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noConsole": "off"
			}
		}
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } }
}
