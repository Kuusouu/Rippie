{
	"name": "rippie",
	"version": "0.1.0",
	"description": "A discord bot built by a dreamer.",
	"main": "src/main.ts",
	"scripts": {
		"dev": "bun --watch src/main.ts",
		"build": "tsc --noEmit",
		"start": "bun src/main.ts",
		"sync": "bun src/deploy-commands.js",
		"format": "bunx prettier --write .",
		"format-check": "bunx prettier --check ."
	},
