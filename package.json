	},
	"homepage": "https://github.com/Kuusouu/Rippie#readme",
	"dependencies": {
		"bufferutil": "^4.1.0",
		"discord.js": "^14.26.4",
		"dotenv": "^17.4.2",
		"fastest-levenshtein": "^1.0.16",
		"ytmusic-api": "^5.3.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
